generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Preorder {
  id           Int       @id @default(autoincrement())
  name         String
  products     Int
  preorderWhen String
  startsAt     DateTime
  endsAt       DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
